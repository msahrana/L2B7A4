model Profile {
  id            String   @id @default(uuid())

  userId        String   @unique

  fullName      String

  phone         String?

  gender        String?

  dateOfBirth   DateTime?

  address       String?

  city          String?

  country       String?

  postalCode    String?

  profilePhoto  String?

  bio           String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("Profiles")
}
