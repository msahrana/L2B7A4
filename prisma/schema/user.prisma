model User {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  password    String
  phone       String?
  profile     Profile?
  role        Role
  status      UserStatus @default(ACTIVE)

  properties  Property[]
  rentals     RentalRequest[]
  payments    Payment[]
  reviews     Review[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("Users")
}